# =============================================
# VIPRNESTORE - Environment Variables
# Copy file ini ke .env dan isi nilainya
# =============================================

# Supabase (wajib)
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyXXXXXXXXX...  # service_role key (bukan anon key!)

# JWT Secret (wajib - buat string random panjang)
JWT_SECRET=ganti_dengan_string_random_sangat_panjang_minimal_64_karakter

# Admin credentials (opsional, bisa diatur via panel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# App
NODE_ENV=production
PORT=3000
