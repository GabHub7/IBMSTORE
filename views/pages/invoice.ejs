<div class="container invoice-page">
<div class="invoice-card">
<div class="invoice-header">
<h2>CEK INVOICE</h2>
</div>
<div class="invoice-body">

<div class="invoice-search-box" style="margin-bottom:24px;">
<form action="/invoice" method="get" style="display:flex;gap:12px;align-items:center;">
<input type="text" name="q" id="invoiceSearchInput" placeholder="Masukkan Invoice ID (contoh: INV-XXXXX-XXXX)" value="<%= searchQuery || '' %>" autocomplete="off" style="flex:1;">
<button type="submit" class="btn btn-primary btn-sm">
<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
Cek
</button>
<% if (searchQuery) { %>
<a href="/invoice" class="btn btn-secondary btn-sm">Reset</a>
<% } %>
</form>
</div>

<% if (!searchQuery) { %>
<div style="text-align:center;padding:40px 20px;">
<svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.25;margin-bottom:20px;display:block;margin-left:auto;margin-right:auto;">
<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
<polyline points="14 2 14 8 20 8"></polyline>
<line x1="16" y1="13" x2="8" y2="13"></line>
<line x1="16" y1="17" x2="8" y2="17"></line>
</svg>
<h3 style="font-size:18px;margin-bottom:8px;color:var(--text-primary);">Masukkan Invoice ID</h3>
<p style="color:var(--text-secondary);font-size:14px;">Invoice ID dikirim setelah pembelian berhasil.<br>Format: <code style="color:var(--cyan);font-size:13px;">INV-XXXXX-XXXX</code></p>
<% const invWaLink = (settings && settings.whatsappLinks && settings.whatsappLinks.length > 0) ? settings.whatsappLinks[0].url : (settings && settings.contact && settings.contact.whatsapp ? 'https://wa.me/' + settings.contact.whatsapp.replace(/\D/g,'') : null); %>
<% if (invWaLink) { %>
<div style="margin-top:24px;">
<a href="<%= invWaLink %>" target="_blank" class="btn btn-secondary" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;">
<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
Hubungi Admin
</a>
</div>
<% } %>
</div>

<div id="localHistorySection" style="margin-top:32px;padding:20px;background:var(--bg-card);border-radius:12px;border:1px solid var(--border);">
<h4 style="color:var(--text-primary);margin-bottom:16px;font-size:15px;display:flex;align-items:center;gap:8px;">
<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
Riwayat Pembelian Saya
</h4>
<div id="localHistoryList" style="display:flex;flex-direction:column;gap:12px;">
<p style="color:var(--text-secondary);font-size:13px;text-align:center;padding:20px 0;">Memuat riwayat...</p>
</div>
</div>

<% } else if (transactions.length === 0) { %>
<div style="text-align:center;padding:40px 20px;">
<svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.3;margin-bottom:16px;display:block;margin-left:auto;margin-right:auto;">
<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
</svg>
<h3 style="font-size:18px;margin-bottom:8px;">Invoice Tidak Ditemukan</h3>
<p style="color:var(--text-secondary);font-size:14px;">Invoice ID "<strong><%= searchQuery %></strong>" tidak ditemukan.<br>Pastikan ID yang dimasukkan sudah benar.</p>
<% const invWaLink2 = (settings && settings.whatsappLinks && settings.whatsappLinks.length > 0) ? settings.whatsappLinks[0].url : (settings && settings.contact && settings.contact.whatsapp ? 'https://wa.me/' + settings.contact.whatsapp.replace(/\D/g,'') : null); %>
<% if (invWaLink2) { %>
<div style="margin-top:20px;display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
<a href="/invoice" class="btn btn-secondary btn-sm">Coba Lagi</a>
<a href="<%= invWaLink2 %>" target="_blank" class="btn btn-secondary btn-sm" style="display:inline-flex;align-items:center;gap:6px;">
<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
WhatsApp Admin
</a>
</div>
<% } else { %>
<a href="/invoice" class="btn btn-secondary btn-sm" style="margin-top:16px;">Coba Lagi</a>
<% } %>
</div>

<% } else { %>
<div class="invoice-transactions">
<% transactions.forEach(t => { %>
<div class="invoice-transaction">
<div class="invoice-transaction-info">
<div class="invoice-transaction-name"><%= t.productName %></div>
<div style="display:flex;gap:8px;align-items:center;margin-top:4px;flex-wrap:wrap;">
<span style="color:var(--text-secondary);font-size:12px;"><%= t.duration %></span>
<span style="color:var(--text-secondary);font-size:12px;">•</span>
<span style="color:var(--text-secondary);font-size:12px;"><%= new Date(t.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
</div>
<% if (t.invoiceId) { %>
<div style="margin-top:4px;">
<span style="color:var(--yellow);font-size:11px;font-weight:600;">Invoice: <%= t.invoiceId %></span>
</div>
<% } %>
<% if (t.status === 'pending' && t.paymentQr) { %>
<div style="margin-top:8px;">
<img src="/qr/<%= encodeURIComponent(t.paymentQr) %>" alt="QRIS" style="width:100px;height:100px;border-radius:6px;border:1px solid rgba(255,255,255,0.1);" />
<p style="color:var(--yellow);font-size:11px;margin:4px 0 0 0;">Rp <%= (t.price / 1000).toFixed(0) %>K</p>
<button onclick="cancelPayment('<%= t.paymentRef %>')" class="btn btn-secondary btn-sm" style="margin-top:6px;font-size:11px;padding:4px 10px;border-color:rgba(239,68,68,0.4);color:#ef4444;">Batalkan</button>
</div>
<% } else if (t.status === 'cancelled' && t.paymentQr) { %>
<div style="margin-top:8px;">
<img src="/qr/<%= encodeURIComponent(t.paymentQr) %>" alt="QRIS" style="width:100px;height:100px;border-radius:6px;border:1px solid rgba(255,255,255,0.1);opacity:0.4;" />
<p style="color:var(--red);font-size:11px;margin:4px 0 0 0;text-decoration:line-through;">Rp <%= (t.price / 1000).toFixed(0) %>K</p>
<span style="color:var(--red);font-size:10px;">Dibatalkan</span>
</div>
<% } %>
</div>
<div class="invoice-transaction-status">
<% if (t.key && (t.status === 'completed' || t.status === 'success')) { %>
<span class="invoice-transaction-key" style="cursor:pointer;" onclick="copyKey('<%= t.key %>')" title="Klik untuk salin"><%= t.key %></span>
<% } else if (t.status === 'pending') { %>
<span style="color:var(--yellow);font-size:12px;font-style:italic;">Menunggu pembayaran...</span>
<% } else if (t.status === 'cancelled') { %>
<span style="color:var(--red);font-size:12px;font-style:italic;">Dibatalkan</span>
<% } else { %>
<span style="color:var(--text-secondary);font-size:12px;font-style:italic;">—</span>
<% } %>
<span class="badge <%= (t.status === 'completed' || t.status === 'success') ? 'badge-completed' : t.status === 'pending' ? 'badge-pending' : 'badge-cancelled' %>" style="margin-left:12px;">
<%= (t.status === 'completed' || t.status === 'success') ? 'Selesai' : t.status === 'pending' ? 'Pending' : 'Cancelled' %>
</span>
</div>
</div>
<% }); %>
</div>

<% if (pendingCount > 0) { %>
<div style="margin-top:24px;padding:20px;background:rgba(250,204,21,.08);border:1px solid rgba(250,204,21,.2);border-radius:12px;">
<h4 style="color:var(--yellow);margin-bottom:12px;font-size:14px;">Pembayaran Pending</h4>
<p style="color:var(--text-secondary);font-size:13px;margin-bottom:16px;"><%= pendingCount %> pembayaran belum dikonfirmasi. Selesaikan pembayaran dan cek status.</p>
<button onclick="checkAllPending()" class="btn btn-primary btn-sm">
<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
Cek Pembayaran
</button>
</div>
<% } %>
<% } %>

</div>
</div>
</div>
<script>
function copyKey(key) {
  navigator.clipboard.writeText(key);
  showToast('Key berhasil disalin!', 'success');
}

function cancelPayment(refId) {
  if (!confirm('Yakin ingin membatalkan pembayaran ini?')) return;
  fetch('/cancel-payment/' + refId, { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        showToast('Pembayaran berhasil dibatalkan', 'success');
        setTimeout(function() { location.reload(); }, 1500);
      } else {
        showToast(data.message || 'Gagal membatalkan', 'error');
      }
    })
    .catch(function() {
      showToast('Gagal membatalkan pembayaran', 'error');
    });
}

<% if (pendingCount > 0) { %>
var pendingRefs = <%- JSON.stringify(pendingRefs) %>;
var checkIndex = 0;
function checkAllPending() {
  if (checkIndex >= pendingRefs.length) {
    showToast('Cek selesai! Refresh halaman untuk melihat update.', 'success');
    setTimeout(function() { location.reload(); }, 2000);
    return;
  }
  var refId = pendingRefs[checkIndex];
  fetch('/check-payment/' + refId, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      checkIndex++;
      if (checkIndex < pendingRefs.length) {
        checkAllPending();
      } else {
        showToast('Cek selesai! Refresh halaman untuk melihat update.', 'success');
        setTimeout(function() { location.reload(); }, 2000);
      }
    })
    .catch(function() {
      checkIndex++;
      if (checkIndex < pendingRefs.length) {
        checkAllPending();
      } else {
        showToast('Cek selesai!', 'success');
        setTimeout(function() { location.reload(); }, 2000);
      }
    });
}
<% } %>

function getLocalHistory() {
  try {
    return JSON.parse(localStorage.getItem('invoiceHistory') || '[]');
  } catch (e) {
    return [];
  }
}

function formatDate(dateStr) {
  if (!dateStr) return '-';
  var d = new Date(dateStr);
  return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function getStatusLabel(status) {
  var labels = {
    'pending': 'Pending',
    'success': 'Selesai',
    'completed': 'Selesai',
    'expired': 'Kadaluarsa',
    'cancelled': 'Dibatalkan'
  };
  return labels[status] || status;
}

function getStatusClass(status) {
  if (status === 'success' || status === 'completed') return 'color:#22c55e;';
  if (status === 'pending') return 'color:var(--yellow);';
  return 'color:var(--red);';
}

function renderLocalHistory(history) {
  var container = document.getElementById('localHistoryList');
  if (!container) return;

  if (history.length === 0) {
    container.innerHTML = '<p style="color:var(--text-secondary);font-size:13px;text-align:center;padding:20px 0;">Belum ada riwayat pembelian.</p>';
    return;
  }

  var html = '';
  history.forEach(function(item) {
    var statusStyle = getStatusClass(item.status);
    html += '<div style="padding:14px;background:var(--bg-primary);border-radius:8px;border:1px solid var(--border);">' +
      '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">' +
      '<div style="font-weight:600;font-size:14px;color:var(--text-primary);">' + (item.productName || 'Produk') + '</div>' +
      '<span style="font-size:10px;font-weight:600;' + statusStyle + ';">' + getStatusLabel(item.status) + '</span>' +
      '</div>' +
      '<div style="font-size:11px;color:var(--text-secondary);margin-bottom:4px;">' + (item.duration || '') + '</div>';

    if (item.invoiceId) {
      html += '<div style="font-size:10px;color:var(--yellow);margin-bottom:4px;font-family:monospace;">' + item.invoiceId + '</div>';
    }

    if (item.key && (item.status === 'success' || item.status === 'completed')) {
      html += '<div style="margin-top:8px;padding:8px 10px;background:var(--bg-card);border-radius:6px;display:flex;justify-content:space-between;align-items:center;">' +
        '<span style="font-size:12px;font-weight:600;color:var(--text-primary);">' + item.key + '</span>' +
        '<button onclick="copyKey(\'' + item.key + '\')" style="background:var(--yellow);border:none;border-radius:4px;padding:4px 8px;cursor:pointer;font-size:11px;color:#000;font-weight:600;">Salin</button>' +
        '</div>';
    } else if (item.status === 'pending') {
      html += '<div style="margin-top:8px;padding:8px 10px;background:var(--bg-card);border-radius:6px;text-align:center;">' +
        '<span style="font-size:11px;color:var(--yellow);font-style:italic;">Menunggu konfirmasi pembayaran</span>' +
        '</div>';
    }

    html += '<div style="font-size:10px;color:var(--text-secondary);margin-top:8px;">' + formatDate(item.createdAt) + '</div>' +
      '</div>';
  });

  container.innerHTML = html;
}

function loadAndMergeHistory() {
  var localHistory = getLocalHistory();
  var invoiceIds = localHistory.map(function(item) { return item.invoiceId; }).filter(function(id) { return id; });

  if (invoiceIds.length === 0) {
    renderLocalHistory(localHistory);
    return;
  }

  fetch('/api/invoice-history?ids=' + encodeURIComponent(invoiceIds.join(',')))
    .then(function(r) { return r.json(); })
    .then(function(serverData) {
      if (serverData && serverData.invoices && serverData.invoices.length > 0) {
        var serverMap = {};
        serverData.invoices.forEach(function(inv) {
          serverMap[inv.invoiceId.toLowerCase()] = inv;
        });

        var mergedHistory = localHistory.map(function(item) {
          if (item.invoiceId && serverMap[item.invoiceId.toLowerCase()]) {
            var serverInv = serverMap[item.invoiceId.toLowerCase()];
            return {
              invoiceId: item.invoiceId,
              paymentRef: item.paymentRef || serverInv.paymentRef || '',
              productName: serverInv.productName || item.productName,
              duration: serverInv.duration || item.duration,
              price: item.price,
              key: serverInv.key || item.key,
              status: serverInv.status || item.status,
              paidAt: serverInv.paidAt || item.paidAt,
              createdAt: serverInv.createdAt || item.createdAt
            };
          }
          return item;
        });

        localStorage.setItem('invoiceHistory', JSON.stringify(mergedHistory));
        renderLocalHistory(mergedHistory);
      } else {
        renderLocalHistory(localHistory);
      }
    })
    .catch(function() {
      renderLocalHistory(localHistory);
    });
}

document.addEventListener('DOMContentLoaded', function() {
  <% if (!searchQuery) { %>
  loadAndMergeHistory();
  <% } %>
});
</script>