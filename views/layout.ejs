<%
const siteTitle = (settings?.siteName || 'IBM STORE').trim() || 'IBM STORE';
const brandName = (settings?.gamePanelName || 'IBM STORE').trim() || 'IBM STORE';
const contact = settings?.contact || {};
const whatsappLinks = Array.isArray(settings?.whatsappLinks) ? settings.whatsappLinks : [];
const telegramLinks = Array.isArray(settings?.telegramLinks) ? settings.telegramLinks : [];
const allContactLinks = [
  ...whatsappLinks.map(l => ({ ...l, type: 'whatsapp' })),
  ...telegramLinks.map(l => ({ ...l, type: 'telegram' }))
];
%>
<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= siteTitle %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="toast-container" id="toastContainer"></div>

<nav class="nav-main">
<div class="container nav-inner">
  <a href="/" class="nav-brand">
    <% if (settings && settings.logo) { %>
    <img src="<%= settings.logo %>" alt="<%= brandName %>">
    <% } else { %>
    <img src="/images/logo-ibm.jpg" alt="<%= brandName %>" onerror="this.style.display='none'">
    <% } %>
    <span><%= brandName %></span>
  </a>
  <div class="nav-links" id="navLinks">
    <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Beranda</a>
    <a href="/invoice" class="nav-link <%= currentPath === '/invoice' ? 'active' : '' %>">Invoice</a>
    <a href="/cara-beli" class="nav-link <%= currentPath === '/cara-beli' ? 'active' : '' %>">Cara Beli</a>
    <% if (isAdmin) { %><a href="/admin" class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>">Admin</a><% } %>
  </div>
  <div class="nav-user">
    <% if (isAdmin) { %>
    <span class="nav-username">Admin</span>
    <a href="/logout" class="btn-logout">Logout</a>
    <% } else { %>
    <a href="/admin-login" class="btn btn-sm btn-outline">Masuk</a>
    <% } %>
  </div>
  <button class="nav-hamburger" id="navHamburger" aria-label="Menu" onclick="toggleMobileMenu()">
    <span class="ham-bar"></span>
    <span class="ham-bar"></span>
    <span class="ham-bar"></span>
  </button>
</div>
<div class="mobile-menu" id="mobileMenu">
  <a href="/" class="nav-link">Beranda</a>
  <a href="/invoice" class="nav-link">Invoice</a>
  <a href="/cara-beli" class="nav-link">Cara Beli</a>
  <% if (isAdmin) { %><a href="/admin" class="nav-link">Admin</a><% } %>
  <div class="mobile-menu-actions">
    <% if (isAdmin) { %>
    <a href="/logout" class="btn btn-sm btn-danger">Logout</a>
    <% } else { %>
    <a href="/admin-login" class="btn btn-sm btn-outline">Masuk</a>
    <% } %>
  </div>
</div>
</nav>

<main><%- body %></main>

<%- include('partials/footer') %>

<!-- Contact Sidebar -->
<div class="contact-sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
<div class="contact-sidebar" id="contactSidebar">
  <div class="sidebar-header">
    <h3>SALURAN & KONTAK</h3>
    <button class="sidebar-close" onclick="closeSidebar()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="sidebar-body">
    <div class="sidebar-label">CONTACT & CHANNELS</div>
    <% allContactLinks.forEach(function(link) {
      const isChannel = link.url && link.url.includes('/channel/');
      const isGroup = link.url && (link.url.includes('chat.whatsapp') || link.url.includes('/g/'));
      const subLabel = link.type === 'telegram' ? 'Telegram' : (isChannel ? 'WA Channel' : isGroup ? 'WA Grup' : 'WhatsApp');
    %>
    <a href="<%= link.url %>" target="_blank" class="contact-item">
      <div class="contact-item-icon <%= link.type === 'whatsapp' ? 'wa' : 'tg' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color:<%= link.type === 'whatsapp' ? '#25d366' : '#0088cc' %>">
          <% if (link.type === 'whatsapp') { %>
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          <% } else { %>
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          <% } %>
        </svg>
      </div>
      <div class="contact-item-text">
        <strong><%= link.title %></strong>
        <span><%= subLabel %></span>
      </div>
    </a>
    <% }); %>
    <% if (allContactLinks.length === 0) { %>
    <p style="color:var(--text-muted);font-size:13px;padding:8px 4px;">Belum ada kontak yang dikonfigurasi.</p>
    <% } %>
    <div class="sidebar-divider"></div>
    <div class="sidebar-info">
      <strong>Jam Operasional</strong>
      Senin - Minggu, 00.00 - 23.59 WIB. Order diproses otomatis 24 jam.
    </div>
  </div>
</div>

<button class="contact-fab" id="contactFab" onclick="openSidebar()" title="Hubungi Kami">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
</button>

<script>
function toggleMobileMenu() {
  document.getElementById('mobileMenu').classList.toggle('open');
}
function openSidebar() {
  document.getElementById('contactSidebar').classList.add('open');
  document.getElementById('sidebarOverlay').classList.add('open');
}
function closeSidebar() {
  document.getElementById('contactSidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('open');
}
function showToast(message, type) {
  var container = document.getElementById('toastContainer');
  var toast = document.createElement('div');
  toast.className = 'toast ' + (type || 'success');
  toast.innerHTML = '<div class="toast-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">' + (type === 'error' ? '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>' : '<polyline points="20 6 9 17 4 12"/>') + '</svg></div><span>' + message + '</span>';
  container.appendChild(toast);
  setTimeout(function() { toast.style.opacity='0'; toast.style.transition='opacity .3s'; setTimeout(function(){toast.remove();},300); }, 4000);
}
</script>
<script src="/js/app.js"></script>
</body>
</html>
